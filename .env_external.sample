# ============================================================
# .env_external.sample
#
# Copie este arquivo para .env_external e preencha os valores.
# O arquivo .env_external NAO deve ser versionado (esta no .gitignore).
#
# Uso: cp .env_external.sample .env_external
# ============================================================

# GeoServer
GEOSERVER_URL=http://localhost:8080/geoserver
GS_USER=admin
GS_PASS=geoserver

# Banco externo
EXT_DB_HOST=
EXT_DB_PORT=5432
EXT_DB_NAME=
EXT_DB_SCHEMA=public
EXT_DB_USER=
EXT_DB_PASS=

# GeoServer workspace/datastore
GS_WORKSPACE=geonode
GS_DATASTORE_NAME=
